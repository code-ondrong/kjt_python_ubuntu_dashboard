# ── Python ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/

# ── Secrets / environment files ─────────────────────────────────────────
# NOTE: `.env/` alone only matches a directory — the bare `.env` file below
# is what keeps SERVER_SSH / ROOT_USER / ROOT_PASSWORD out of git.
.env
.env.*
!.env.example

# ── Virtual environments ────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── IDE / Editor ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Project-specific ────────────────────────────────────────────────────
# Local override / testing files
*.local.py
